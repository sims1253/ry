{
  "schema_version": "1",
  "package": "shiny",
  "version": "0.0.1",
  "functions": {
    "moduleServer": {
      "params": [
        "id",
        "module",
        "session"
      ],
      "injects": [
        {
          "into": [
            "module"
          ],
          "names": [
            "session",
            "input",
            "output"
          ]
        }
      ],
      "return": {
        "mode": "opaque",
        "length": "unknown",
        "na": false
      }
    },
    "testServer": {
      "params": [
        "app",
        "expr",
        "..."
      ],
      "eval": {
        "expr": "quoted_expression"
      },
      "injects": [
        {
          "into": [
            "expr"
          ],
          "names": [
            "session",
            "input",
            "output"
          ]
        }
      ],
      "return": {
        "mode": "null",
        "length": "0",
        "na": false
      }
    },
    "reactive": {
      "params": ["x", "..."],
      "eval": {"x": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "observe": {
      "params": ["x", "..."],
      "eval": {"x": "quoted_expression"},
      "return": {"mode": "opaque", "length": "unknown", "na": false}
    },
    "observeEvent": {
      "params": ["eventExpr", "handlerExpr", "..."],
      "eval": {
        "eventExpr": "quoted_expression",
        "handlerExpr": "quoted_expression"
      },
      "return": {"mode": "opaque", "length": "unknown", "na": false}
    },
    "eventReactive": {
      "params": ["eventExpr", "valueExpr", "..."],
      "eval": {
        "eventExpr": "quoted_expression",
        "valueExpr": "quoted_expression"
      },
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "isolate": {
      "params": ["expr"],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "opaque", "length": "unknown", "na": false}
    },
    "renderText": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderPrint": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderUI": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderPlot": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderTable": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderDataTable": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    },
    "renderImage": {
      "params": ["expr", "..."],
      "eval": {"expr": "quoted_expression"},
      "return": {"mode": "function", "length": "1", "na": false}
    }
  }
