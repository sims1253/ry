    "brms.prior": {
      "params": ["prior", "..."],
      "eval": { "prior": "quoted_expression", "...": "quoted_expression", "check": "normal" },
      "return": { "mode": "list", "length": "unknown", "na": false, "class": ["brmsprior", "data.frame"] }
    },
    "brms.brm": {
