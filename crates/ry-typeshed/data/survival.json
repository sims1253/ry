{
  "version": "0.0.1",
  "functions": {
    "Surv": {
      "params": ["time", "event", "..."],
      "return": { "mode": "opaque", "length": "unknown", "na": false, "class": ["Surv"] }
    },
    "survfit": {
      "params": ["formula", "data", "..."],
      "return": { "mode": "list", "length": "unknown", "na": false, "class": ["survfit"] }
    }
  },
  "s3_methods": [
    {
      "generic": "quantile",
      "class": "survfit",
      "params": ["x", "..."],
      "return": {
        "mode": "list",
        "length": "unknown",
        "na": true,
        "columns": {
          "quantile": { "mode": "double", "length": "unknown", "na": true },
          "lower": { "mode": "double", "length": "unknown", "na": true },
          "upper": { "mode": "double", "length": "unknown", "na": true }
        }
      }
    },
    {
      "generic": "summary",
      "class": "survfit",
      "params": ["object", "..."],
      "return": { "mode": "list", "length": "unknown", "na": true }
    }
  ]
}
